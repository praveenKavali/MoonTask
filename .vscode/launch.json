    "version": "0.2.0",
    "configurations": [
    {
        "name": "Attach by com.sun.jdi.SharedMemoryListen",
        "type": "jdk",
        "request": "attach",
        "listen": "true"
    },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "BackendApplication",
            "request": "launch",
            "mainClass": "com.MoonTask.Backend.BackendApplication",
            "projectName": "Backend",
            "vmArgs": "-Duser.timezone=Asia/Kolkata"
        }
    ]
}